{
  "name": "demo_application",
  "version": "1.0.0",
  "description": "Playwright and FlaUI desktop automation demo for Windows applications.",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "report": "playwright show-report test-results/playwright/report --port 0",
