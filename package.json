    "type": "git",
    "url": "git+https://github.com/your-org/demo_Application.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/demo_Application/issues"
  },
  "homepage": "https://github.com/your-org/demo_Application#readme",
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "typescript": "^5.8.3"
  }
}
